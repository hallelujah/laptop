#!/bin/sh

# Welcome to the thoughtbot laptop script (Fedora edition)!
# Be prepared to turn your machine
# into an awesome development machine.

# shellcheck disable=SC3043

fancy_echo() {
  local fmt="$1"
  shift

  # shellcheck disable=SC2059
  printf "\\n$fmt\\n" "$@"
}

# shellcheck disable=SC2154
trap 'ret=$?; test $ret -ne 0 && printf "failed\\n\\n" >&2; exit $ret' EXIT

set -e

if [ ! -d "$HOME/.bin/" ]; then
  mkdir "$HOME/.bin"
fi

update_shell() {
  local shell_path
  shell_path="/usr/bin/zsh"

  fancy_echo "Changing your shell to zsh ..."
  if ! grep "$shell_path" /etc/shells >/dev/null 2>&1; then
    fancy_echo "Installing zsh package"
    sudo dnf install -y zsh
  fi
  sudo chsh -s "$shell_path" "$USER"
}

case "$SHELL" in
*/zsh) ;;
*)
  update_shell
  ;;
esac

fancy_echo "Updating dnf repositories ..."
sudo dnf check-update || true

# heroku-cli and yarn are often easier to install via mise/npm if not in dnf
# Docker on Fedora is often replaced by podman, or you install docker-ce from their repo.
# For simplicity, we'll stick to what's likely available or commonly used.

# Add github-cli repo if 'gh' is not found (though it is often in Fedora repos)
if ! rpm -q gh >/dev/null 2>&1; then
  if dnf --version | grep -q "dnf5"; then
    sudo dnf config-manager addrepo --overwrite --from-repofile=https://cli.github.com/packages/rpm/gh-cli.repo
  else
    sudo dnf config-manager --add-repo https://cli.github.com/packages/rpm/gh-cli.repo
  fi
fi

fancy_echo "Installing core packages via dnf ..."
sudo dnf install -y \
  ctags \
  zoxide \
  git \
  openssl \
  openssl-devel \
  rcm \
  ripgrep \
  tmux \
  neovim \
  gh \
  vips \
  poppler-utils \
  libyaml-devel \
  coreutils \
  gnupg2 \
  postgresql-server \
  postgresql-contrib \
  redis \
  util-linux-user \
  gcc-c++ \
  make \
  patch \
  bzip2 \
  perl-core \
  libffi-devel \
  zlib-devel \
  readline-devel \
  gdbm-devel \
  ncurses-devel \
  gawk \
  pinentry-curses \
  hostname \
  xz \
  chromium \
  libatomic \
  shellcheck \
  keychain

# Mise installation
if ! command -v mise >/dev/null; then
  fancy_echo "Installing mise ..."
  curl https://mise.run | sh

  export PATH="$HOME/.local/bin:$PATH"
fi

fancy_echo "Configuring mise ..."

# mise plugins (some are built-in or don't need explicit 'plugin add' if using default registry)
# For parity with the previous setup, we ensure they're available.
if command -v mise >/dev/null; then
  mise use -g ruby@latest
  mise use -g node@latest
  mise use -g minio@latest

  fancy_echo "Installing latest Ruby via mise ..."
  mise install ruby@latest
  mise use -g ruby@latest

  mise exec ruby@latest -- gem update --system
  number_of_cores=$(nproc)
  mise exec ruby@latest -- bundle config --global jobs $((number_of_cores - 1))

  fancy_echo "Installing latest Node via mise ..."
  mise install node@latest
  mise use -g node@latest
fi

if [ -f "$HOME/.setup.local" ]; then
  fancy_echo "Running your customizations from ~/.setup.local ..."
  # shellcheck disable=SC1091
  . "$HOME/.setup.local"
fi
