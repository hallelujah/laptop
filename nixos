#!/bin/sh

# Welcome to the thoughtbot laptop script (NixOS edition)!
# Be prepared to turn your machine
# into an awesome development machine.

# shellcheck disable=SC3043

fancy_echo() {
  local fmt="$1"
  shift

  # shellcheck disable=SC2059
  printf "\\n$fmt\\n" "$@"
}

# shellcheck disable=SC2154
trap 'ret=$?; test $ret -ne 0 && printf "failed\\n\\n" >&2; exit $ret' EXIT

set -e

if [ ! -d "$HOME/.bin/" ]; then
  mkdir "$HOME/.bin"
fi

update_shell() {
  local shell_path
  shell_path="/run/current-system/sw/bin/zsh"

  fancy_echo "Changing your shell to zsh ..."
  if [ ! -f "$shell_path" ]; then
    fancy_echo "zsh not found at $shell_path. Please ensure it is installed via your NixOS configuration."
    return
  fi
  sudo chsh -s "$shell_path" "$USER"
}

case "$SHELL" in
*/zsh) ;;
*)
  update_shell
  ;;
esac

fancy_echo "Installing core packages via nix-env ..."
# "Smart" installation: use nix-env to install from install.nix
# This allows declarative-ish management of user-profile packages.
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
nix-env -iA -f "$SCRIPT_DIR/install.nix"

if [ -f "$HOME/.setup.local" ]; then
  fancy_echo "Running your customizations from ~/.setup.local ..."
  # shellcheck disable=SC1091
  . "$HOME/.setup.local"
fi
